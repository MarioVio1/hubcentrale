{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@multimedia/*": [
        "./src/app/(sections)/multimedia/*"
      ],
      "@cosmetica/*": [
        "./src/app/(sections)/cosmetica/*"
      ],
      "@libri/*": [
        "./src/app/(sections)/libri/*"
      ],
      "@lunastar/*": [
        "./src/app/(sections)/lunastar/*"
      ],
      "@manga/*": [
        "./src/app/(sections)/manga/*"
      ],
      "@pokemon/*": [
        "./src/app/(sections)/pokemon/*"
      ],
      "@livetv/*": [
        "./src/app/(sections)/livetv/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}

# Hub Centrale — Reverse Proxy
# Sostituisci il dominio con il tuo (es. tuo-sito.com)

# Landing page
tuodominio.com {
    root * /srv/hub
    file_server
}

# Sottodomini per ogni sezione
multimedia.tuodominio.com {
    reverse_proxy localhost:3001
}

cosmetica.tuodominio.com {
    reverse_proxy localhost:3002
}

libri.tuodominio.com {
    reverse_proxy localhost:3003
}

lunastar.tuodominio.com {
    reverse_proxy localhost:3004
}

manga.tuodominio.com {
    reverse_proxy localhost:3005
}

pokemon.tuodominio.com {
    reverse_proxy localhost:3006
}

# Per sviluppo locale
localhost {
    root * /srv/hub
    file_server

    handle /multimedia/* {
        reverse_proxy localhost:3001
    }
    handle /cosmetica/* {
        reverse_proxy localhost:3002
    }
    handle /libri/* {
        reverse_proxy localhost:3003
    }
    handle /lunastar/* {
        reverse_proxy localhost:3004
    }
    handle /manga/* {
        reverse_proxy localhost:3005
    }
    handle /pokemon/* {
        reverse_proxy localhost:3006
    }
}

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  output = "../../node_modules/@prisma/multimedia-client"
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_MULTIMEDIA")
}

model Favorite {
  id          String   @id @default(cuid())
  mediaId     Int      // TMDB ID
  mediaType   String   // "movie" or "tv"
  title       String
  posterPath  String?
  overview    String?
  voteAverage Float?
  releaseDate String?
  createdAt   DateTime @default(now())
  
  @@unique([mediaId, mediaType])
}

model WatchHistory {
  id          String   @id @default(cuid())
  mediaId     Int      // TMDB ID
  mediaType   String   // "movie" or "tv"
  title       String
  posterPath  String?
  overview    String?
  voteAverage Float?
  releaseDate String?
  season      Int?
  episode     Int?
  progress    Float    @default(0) // 0-100 percentage
  watchedAt   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([mediaId, mediaType])
}

model UserSettings {
  id        String   @id @default(cuid())
  theme     String   @default("dark")
  language  String   @default("en")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

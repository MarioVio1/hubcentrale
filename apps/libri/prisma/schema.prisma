// ShadowKindle - Personal Ebook Reader
// Self-hosted ebook reader with support for EPUB and PDF files

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model for authentication (optional, for multi-user support)
model User {
  id             String              @id @default(cuid())
  email          String              @unique
  name           String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  books          Book[]
  progress       ReadingProgress[]
  readingGoals   ReadingGoal[]
  readingSession ReadingSession[]
}

// Book model - represents an ebook in the library
model Book {
  id           String   @id @default(cuid())
  title        String
  author       String
  description  String?
  coverPath    String?  // Path to cover image
  filePath     String   // Path to EPUB/PDF file
  fileType     String   // "epub" or "pdf"
  fileSize     Int      // File size in bytes
  totalPages   Int?     // Total pages/locations
  category     String   @default("wishlist") // "reading", "completed", "wishlist"
  addedAt      DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  progress     ReadingProgress[]
  bookmarks    Bookmark[]
  highlights   Highlight[]
  rating       BookRating?
  collections   BookCollection[]
  sessions     ReadingSession[]
}

// Reading progress tracking
model ReadingProgress {
  id           String   @id @default(cuid())
  bookId       String
  book         Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentPage  Int      @default(0) // Current page or location
  totalPages   Int?
  percentage   Float    @default(0) // Percentage completed (0-100)
  cfi          String?  // EPUB Canonical Fragment Identifier
  lastPosition String?  // JSON string with additional position data
  lastReadAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([bookId, userId])
}

// Bookmarks for saving specific locations
model Bookmark {
  id         String   @id @default(cuid())
  bookId     String
  book       Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  title      String   @default("Untitled Bookmark")
  cfi        String?  // EPUB location
  pageNumber Int?
  note       String?
  createdAt   DateTime @default(now())
}

// Highlights for marked text
model Highlight {
  id        String   @id @default(cuid())
  bookId    String
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  text      String
  cfi       String?  // EPUB location
  color     String   @default("#ffff00") // Yellow by default
  note      String?
  createdAt DateTime @default(now())
}

// Book ratings
model BookRating {
  id        String   @id @default(cuid())
  bookId    String   @unique
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  rating    Int      // 1-5 stars
  review    String?  // User review text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Book collections (custom categories beyond reading/completed/wishlist)
model Collection {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String?  // Hex color for collection tag
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  books       BookCollection[]
}

// Many-to-many relationship between books and collections
model BookCollection {
  id            String     @id @default(cuid())
  bookId        String
  book          Book       @relation(fields: [bookId], references: [id], onDelete: Cascade)
  collectionId  String
  collection    Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  addedAt       DateTime   @default(now())

  @@unique([bookId, collectionId])
}

// Reading goals (e.g., read 10 books this month, read 30 minutes daily)
model ReadingGoal {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String   // e.g., "Read 10 books this month"
  goalType    String   // "books" or "pages" or "minutes"
  target      Int      // Target number
  startDate   DateTime
  endDate     DateTime
  current     Int      @default(0) // Current progress
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Reading sessions for tracking statistics
model ReadingSession {
  id           String   @id @default(cuid())
  bookId       String
  book         Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  duration     Int      // Duration in seconds
  pagesRead   Int      @default(0) // Number of pages read in this session
  startCfi     String?  // EPUB location at start
  endCfi       String?  // EPUB location at end
  createdAt    DateTime @default(now())
}

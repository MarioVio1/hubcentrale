generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============= GAME ROOMS =============
model Room {
  id          String   @id @default(cuid())
  code        String   @unique
  gameType    String   // briscola, uno, forza4, scopa, indovinachi, nomecitta, dama, mercanteinfiera
  phase       String   @default("lobby") // lobby, playing, selecting, auction, writing, judging, results, gameOver
  hostId      String
  vsCpu       Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  players     Player[]
  
  // Game State (stored as JSON for flexibility)
  gameState   Json?    // Full game state object
  
  // Common fields
  currentTurn String?
  winner      String?
  lastAction  Json?    // {playerId, message}
  
  // Forza 4 / Tris
  board       Json?    // 2D array
  
  // Briscola / Scopa
  briscolaSuit String?
  deck        Json?    // Array of cards
  tableCards  Json?    // Cards on table (Scopa)
  currentTrick Json?   // Current trick cards (Briscola)
  discardPile Json?    // UNO discard pile
  
  // UNO specific
  currentColor String?
  direction   Int      @default(1)
  
  // Indovina Chi
  currentQuestioner String?
  currentQuestion String?
  waitingForAnswer Boolean @default(false)
  
  // Nome Città
  currentLetter String?
  timerStart   Int?     // Timestamp when timer started
  
  // Mercante in Fiera
  currentAuction Json?
  auctionCardsSold Int @default(0)
  currentExtraction Json?
}

// ============= PLAYERS =============
model Player {
  id           String   @id @default(cuid())
  persistentId String   // Stored in localStorage
  roomId       String
  name         String
  isHost       Boolean  @default(false)
  isCpu        Boolean  @default(false)
  score        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  room         Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  
  // Cards in hand (JSON array)
  hand         Json?
  
  // Game-specific data
  points       Int      @default(0)     // Briscola points
  money        Int      @default(100)   // Mercante
  cards        Json?                     // Mercante owned cards
  collectedCards Json?                  // Scopa collected cards
  scopas       Int      @default(0)     // Scopa count
  secretCharacter Int?                  // Indovina Chi
  eliminatedCharacters Json?            // Indovina Chi eliminated
  answers      Json?                    // Nome Città answers
  finished     Boolean  @default(false) // Nome Città finished
  playedPunchline Json?                 // Joking Hazard
}

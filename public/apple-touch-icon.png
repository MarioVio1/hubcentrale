<svg xmlns="http://www.w3.org/2000/svg" width="180" height="180" viewBox="0 0 180 180">
  <defs>
    <linearGradient id="appleGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#00d4aa;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#00a088;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="180" height="180" rx="40" fill="#0a0a0f"/>
  <text x="90" y="100" font-family="Arial, sans-serif" font-size="80" font-weight="bold" fill="url(#appleGradient)" text-anchor="middle" dominant-baseline="middle">M</text>
  <text x="90" y="130" font-family="Arial, sans-serif" font-size="30" font-weight="bold" fill="#00d4aa" text-anchor="middle" dominant-baseline="middle">flow</text>
</svg>